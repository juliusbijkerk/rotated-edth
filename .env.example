ANTHROPIC_API_KEY=sk-ant-your-key-here

# HTTP Basic Auth — set ROTATED_PASS to a strong secret to lock the site.
# Browsers prompt for username/password and cache per-origin. WebSocket upgrades
# inherit the same Authorization header, so /ws/unit and /ws/operator are gated too.
# Leave ROTATED_PASS blank to disable auth (NOT recommended on a public domain).
# (Legacy ARGUS_USER / ARGUS_PASS are still accepted.)
ROTATED_USER=rotated
ROTATED_PASS=
