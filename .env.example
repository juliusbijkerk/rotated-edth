ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: use Deepgram instead of local mlx-whisper for STT.
# Keep the real key in .env only; .env is gitignored.
ARGUS_STT_PROVIDER=whisper
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_SMART_FORMAT=true

# Optional: set to an HTTPS tunnel origin so terminal QR codes work with phone mic access.
ARGUS_PUBLIC_BASE_URL=
