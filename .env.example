ANTHROPIC_API_KEY=sk-ant-your-key-here

# HTTP Basic Auth — set ARGUS_PASS to a strong secret to lock the site.
# Browsers prompt for username/password and cache per-origin. WebSocket upgrades
# inherit the same Authorization header, so /ws/unit and /ws/operator are gated too.
# Leave ARGUS_PASS blank to disable auth (NOT recommended on a public domain).
ARGUS_USER=argus
ARGUS_PASS=
